{
  "name": "mysteryforge",
  "version": "1.1.0",
  "description": "Automated fictional mystery/crime story generator for YouTube content",
  "main": "generate.js",
  "scripts": {
    "generate": "node generate.js",
    "synthesize": "node synthesize.js",
    "images": "node fetch-images.js --latest",
    "images:ai": "node fetch-images.js --latest --gemini",
    "assemble": "node assemble-video.js --latest",
    "thumbnails": "node generate-thumbnails.js --latest",
    "pipeline": "node pipeline.js",
    "build": "npm run generate && npm run synthesize && npm run images && npm run assemble",
    "test": "node tests/generate.test.js && node tests/providers.test.js",
    "test:generate": "node tests/generate.test.js",
    "test:providers": "node tests/providers.test.js"
  },
  "keywords": [
    "mystery",
    "story-generator",
    "youtube",
    "ai",
    "content-creation",
    "llm",
    "groq",
    "cerebras",
    "tts",
    "video-generation"
  ],
  "author": "Ronald John Atanoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronaldjohnatanoso/mysteryforge.git"
  },
  "bugs": {
    "url": "https://github.com/ronaldjohnatanoso/mysteryforge/issues"
  },
  "homepage": "https://github.com/ronaldjohnatanoso/mysteryforge#readme",
  "dependencies": {
    "edge-tts": "^1.0.1",
    "gtts": "^0.2.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
