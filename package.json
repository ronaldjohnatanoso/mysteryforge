{
  "name": "mysteryforge",
  "version": "1.6.0",
  "description": "Automated fictional mystery/crime story generator for YouTube content",
  "main": "generate.js",
  "scripts": {
    "generate": "node generate.js",
    "batch": "node batch-generate.js",
    "batch:all": "node batch-generate.js --all-genres",
    "synthesize": "node synthesize.js",
    "images": "node fetch-images.js --latest",
    "images:ai": "node fetch-images.js --latest --gemini",
    "assemble": "node assemble-video.js --latest",
    "thumbnails": "node generate-thumbnails.js --latest",
    "platforms": "node platform-templates.js --latest --all",
    "platforms:youtube": "node platform-templates.js --latest --youtube",
    "platforms:tiktok": "node platform-templates.js --latest --tiktok",
    "upload": "node youtube-upload.js --latest",
    "upload:public": "node youtube-upload.js --latest --public",
    "upload:seo": "node youtube-upload.js --latest --use-seo",
    "optimize": "node src/seo/optimizer.js --latest",
    "pipeline": "node pipeline.js",
    "schedule": "node schedule-queue.js",
    "schedule:add": "node schedule-queue.js --add",
    "schedule:list": "node schedule-queue.js --list",
    "schedule:due": "node schedule-queue.js --due",
    "schedule:run": "node schedule-queue.js --run",
    "test:schedule": "node tests/schedule-queue.test.js",
    "test:seo": "node tests/seo.test.js",
    "test:trending": "node tests/trending.test.js",
    "test:analytics": "node tests/analytics.test.js",
    "trending": "node src/seo/trending.js",
    "trending:list": "node src/seo/trending.js --list",
    "trending:refresh": "node src/seo/trending.js --refresh",
    "analytics": "node src/analytics/feedback.js",
    "analytics:track": "node src/analytics/feedback.js --track",
    "analytics:insights": "node src/analytics/feedback.js --insights",
    "analytics:list": "node src/analytics/feedback.js --list",
    "validate": "node validate-story.js --latest",
    "validate:json": "node validate-story.js --latest --json",
    "build": "npm run generate && npm run synthesize && npm run images && npm run assemble && npm run thumbnails",
    "build:full": "npm run build && npm run platforms",
    "test": "node tests/test-suite.js",
    "test:providers": "node tests/providers.test.js",
    "test:generate": "node tests/generate.test.js",
    "test:broll": "node tests/broll.test.js",
    "test:assembler": "node tests/assembler.test.js",
    "test:subtitles": "node tests/subtitles.test.js"
  },
  "keywords": [
    "mystery",
    "story-generator",
    "youtube",
    "ai",
    "content-creation",
    "llm",
    "groq",
    "cerebras",
    "tts",
    "video-generation"
  ],
  "author": "Ronald John Atanoso",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ronaldjohnatanoso/mysteryforge.git"
  },
  "bugs": {
    "url": "https://github.com/ronaldjohnatanoso/mysteryforge/issues"
  },
  "homepage": "https://github.com/ronaldjohnatanoso/mysteryforge#readme",
  "dependencies": {
    "edge-tts": "^1.0.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "gtts": "^0.2.1",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
